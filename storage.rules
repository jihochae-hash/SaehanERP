rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 기본: 모든 접근 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // 인증된 사용자만 파일 업로드/다운로드 (최대 10MB)
    match /uploads/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
